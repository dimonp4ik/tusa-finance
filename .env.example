# Скопируй этот файл в .env и впиши свои значения.
# НИКОГДА не заливай .env на GitHub — там секреты.

# Telegram-бот: токен от @BotFather и твой chat_id (куда слать сигналы)
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your_chat_id_here

# База данных (Railway: ВАЖНО! установи DB_PATH=/data/tusa_finance.db чтобы она не сбрасывалась)
# DB_PATH=/data/tusa_finance.db

# Всё остальное (yfinance, OKX EU публичные данные, список акций NASDAQ)
# работает БЕЗ ключей — это бесплатные публичные источники.
# Ключи OKX/Trading212 для покупки понадобятся позже, на этапе автоторговли.

# Супер-админ (671071896) уже зашит в config.py, как в других tusa-ботах.
# Сюда можно добавить ДОПОЛНИТЕЛЬНЫХ админов через запятую (необязательно).
# ADMIN_USER_IDS=123456789,987654321

# AI-проверка кандидатов (BUY/SKIP + причина в каждом сигнале) — необязательно.
# Основной вариант: Claude — тот же ключ что у других tusa-ботов.
# Модель по умолчанию claude-haiku-4-5 (~$0.5/мес на нашей нагрузке);
# JUDGE_MODEL=claude-sonnet-5 — умнее, ~$1.5/мес.
# CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# JUDGE_MODEL=claude-haiku-4-5

# Запасной вариант: DeepSeek (если Claude-ключа нет).
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# Новостной сканер-катализатор (ловит заголовок ДО движения цены, каждые
# несколько минут) — БЕЗ ключа полностью выключен, ничего не шлёт.
# Groq бесплатный: https://console.groq.com/keys
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx
# GROQ_MODEL=llama-3.1-8b-instant

# Необязательные настройки (можно не трогать — есть значения по умолчанию в config.py)
# DIV_SCAN_DAY_OF_WEEK=sun            # дивиденды, раз в неделю (apscheduler day name)
# SCAN_HOUR_UTC=19                    # дивиденды/дайджест, вечер по UTC
# MOMENTUM_SCAN_INTERVAL_HOURS=4      # моментум + аномальный объём
# NEWS_SCAN_INTERVAL_MINUTES=5        # новостной сканер-катализатор
# NEWS_LOOKBACK_MINUTES=20            # окно свежести заголовков
# NEWS_SYMBOL_COOLDOWN_HOURS=3        # не спамить один тикер новостями чаще
# HIDE_JUDGE_SKIPPED=1                # прятать SKIP-вердикты AI, не слать вообще
# MOM_DIGEST_TOP_N=5                  # размер общего топа (акции+крипта вместе)
# DIV_MIN_YIELD_PCT=3.0
# MOM_MIN_PRICE_CHANGE_PCT=15.0
