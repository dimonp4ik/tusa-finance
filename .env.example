# Скопируй этот файл в .env и впиши свои значения.
# НИКОГДА не заливай .env на GitHub — там секреты.

# Telegram-бот: токен от @BotFather и твой chat_id (куда слать сигналы)
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your_chat_id_here

# Всё остальное (yfinance, OKX EU публичные данные, список акций NASDAQ)
# работает БЕЗ ключей — это бесплатные публичные источники.
# Ключи OKX/Trading212 для покупки понадобятся позже, на этапе автоторговли.

# Супер-админ (671071896) уже зашит в config.py, как в других tusa-ботах.
# Сюда можно добавить ДОПОЛНИТЕЛЬНЫХ админов через запятую (необязательно).
# ADMIN_USER_IDS=123456789,987654321

# DeepSeek — необязательная вторая проверка кандидатов (BUY/SKIP + причина
# в каждом сигнале). Регистрация на platform.deepseek.com даёт 5 млн токенов
# бесплатно; дальше ~$0.14-0.28 за миллион — проверка 5 кандидатов за скан
# стоит меньше $1/мес. Без ключа бот работает как обычно, просто без вердиктов.
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# Необязательные настройки (можно не трогать — есть значения по умолчанию в config.py)
# SCAN_HOUR_UTC=7                    # дивиденды, раз в сутки
# MOMENTUM_SCAN_INTERVAL_HOURS=4     # моментум + аномальный объём
# MOM_DIGEST_TOP_N=5                 # размер общего топа (акции+крипта вместе)
# DIV_MIN_YIELD_PCT=3.0
# MOM_MIN_PRICE_CHANGE_PCT=15.0
